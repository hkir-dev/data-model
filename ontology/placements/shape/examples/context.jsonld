{
  "@context": {
    "pl":  "https://socialcaredata.github.io/ontology/placements#",
    "cln": "https://socialcaredata.github.io/ontology/placements/vocab/cultural-need#",
    "cn":  "https://socialcaredata.github.io/ontology/placements/vocab/communication-need#",
    "la":  "https://socialcaredata.github.io/ontology/placements/vocab/living-arrangement#",
    "pa":  "https://socialcaredata.github.io/ontology/placements/vocab/pets-allowance#",
    "pt":  "https://socialcaredata.github.io/ontology/placements/vocab/placement-type#",
    "pu":  "https://socialcaredata.github.io/ontology/placements/vocab/placement-urgency#",
    "rl":  "https://socialcaredata.github.io/ontology/placements/vocab/risk-level#",
    "sl":  "https://socialcaredata.github.io/ontology/placements/vocab/suitability-level#",
    "st":  "https://socialcaredata.github.io/ontology/placements/vocab/support-type#",
    "yns": "https://socialcaredata.github.io/ontology/placements/vocab/presence-status#",
    "olr": "https://socialcaredata.github.io/ontology/placements/vocab/outof-la-reason#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "ex":  "https://example.org/placement/",

    "Placement":                 "pl:Placement",
    "PlacementAvailability":     "pl:PlacementAvailability",
    "PlacementRequirements":     "pl:PlacementRequirements",
    "PlacementRecommendation":   "pl:PlacementRecommendation",
    "RiskAssessment":            "pl:RiskAssessment",
    "ActualPlacement":           "pl:ActualPlacement",
    "QualityAssurance":          "pl:QualityAssurance",

    "childId":                       "pl:childId",
    "hasPlacementAvailability":      { "@id": "pl:hasPlacementAvailability",      "@type": "@id" },
    "hasPlacementRequirements":      { "@id": "pl:hasPlacementRequirements",      "@type": "@id" },
    "hasPlacementRecommendation":    { "@id": "pl:hasPlacementRecommendation",    "@type": "@id" },
    "hasRiskAssessment":             { "@id": "pl:hasRiskAssessment",             "@type": "@id" },
    "hasActualPlacement":            { "@id": "pl:hasActualPlacement",            "@type": "@id" },
    "hasQualityAssurance":           { "@id": "pl:hasQualityAssurance",           "@type": "@id" },

    "placementId":          "pl:placementId",
    "neededBy":             { "@id": "pl:neededBy",             "@type": "@id" },
    "siblingCount":         { "@id": "pl:siblingCount",         "@type": "xsd:nonNegativeInteger" },
    "isPreferredLocationLocal":    "pl:isPreferredLocationLocal",
    "outOfLAReason":        { "@id": "pl:outOfLAReason",               "@type": "@id" },

    "communicationNeeds":               { "@id": "pl:communicationNeeds",               "@type": "@id" },
    "specificCommunicationRequirement": { "@id": "pl:specificCommunicationRequirement", "@type": "@id", "@container": "@set" },
    "culturalNeeds":                    { "@id": "pl:culturalNeeds",                    "@type": "@id" },
    "livingCompanions":                 { "@id": "pl:livingCompanions",                 "@type": "@id" },
    "pets":                             { "@id": "pl:pets",                             "@type": "@id" },
    "additionalSupport":                { "@id": "pl:additionalSupport",                "@type": "@id" },
    "additionalSupportOther":           "pl:additionalSupportOther",
    "homeAdaptationRequired":           "pl:homeAdaptationRequired",
    "deprivationOfLiberty":             "pl:deprivationOfLiberty",

    "fosterCareSuitability":            { "@id": "pl:fosterCareSuitability",            "@type": "@id" },
    "residentialCareSuitability":       { "@id": "pl:residentialCareSuitability",       "@type": "@id" },
    "supportedAccommodationSuitability":{ "@id": "pl:supportedAccommodationSuitability","@type": "@id" },

    "riskSelfHarm":              { "@id": "pl:riskSelfHarm",              "@type": "@id" },
    "riskCriminalExploitation":  { "@id": "pl:riskCriminalExploitation",  "@type": "@id" },
    "riskDrugAlcohol":           { "@id": "pl:riskDrugAlcohol",           "@type": "@id" },
    "riskEatingDisorder":        { "@id": "pl:riskEatingDisorder",        "@type": "@id" },
    "riskMissing":               { "@id": "pl:riskMissing",               "@type": "@id" },
    "riskSexualExploitation":    { "@id": "pl:riskSexualExploitation",    "@type": "@id" },
    "riskToOthersPhysical":      { "@id": "pl:riskToOthersPhysical",      "@type": "@id" },
    "riskToOthersSexual":        { "@id": "pl:riskToOthersSexual",        "@type": "@id" },
    "riskToOthersFire":          { "@id": "pl:riskToOthersFire",          "@type": "@id" },
    "riskToOthersAnimals":       { "@id": "pl:riskToOthersAnimals",       "@type": "@id" },
    "riskToOthersCriminal":      { "@id": "pl:riskToOthersCriminal",      "@type": "@id" },
    "riskOther":                 "pl:riskOther",
    "riskToOthersOther":         "pl:riskToOthersOther",

    "placementType":           { "@id": "pl:placementType", "@type": "@id" },
    "providerURN":             "pl:providerURN",
    "placementLocation":       "pl:placementLocation",
    "isLocationPreferred":     "pl:isLocationPreferred",
    "isEducationContinuous":   "pl:isEducationContinuous",
    "siblingsPlacedTogether":  { "@id": "pl:siblingsPlacedTogether", "@type": "xsd:nonNegativeInteger" },
    "totalWeeklyCost":         { "@id": "pl:totalWeeklyCost",        "@type": "xsd:decimal" },
    "coreWeeklyCost":              { "@id": "pl:coreWeeklyCost",              "@type": "xsd:decimal" },
    "additionalSupportWeeklyCost": { "@id": "pl:additionalSupportWeeklyCost", "@type": "xsd:decimal" },
    "educationWeeklyCost":         { "@id": "pl:educationWeeklyCost",         "@type": "xsd:decimal" },
    "otherWeeklyCost":             { "@id": "pl:otherWeeklyCost",             "@type": "xsd:decimal" },

    "referralDate":          { "@id": "pl:referralDate",     "@type": "xsd:date" },
    "referralOfficerName":   "pl:referralOfficerName",
    "placementDate":         { "@id": "pl:placementDate",    "@type": "xsd:date" },
    "placementOfficerName":  "pl:placementOfficerName",
    "costDate":              { "@id": "pl:costDate",         "@type": "xsd:date" },
    "costOfficerName":       "pl:costOfficerName"
  }
}
