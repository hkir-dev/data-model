@prefix : <https://socialcaredata.github.io/ontology/placements#> .
@prefix cn: <https://socialcaredata.github.io/ontology/placements/vocab/communication-need#> .
@prefix la: <https://socialcaredata.github.io/ontology/placements/vocab/living-arrangement#> .
@prefix pa: <https://socialcaredata.github.io/ontology/placements/vocab/pets-allowance#> .
@prefix pl: <https://socialcaredata.github.io/ontology/placements#> .
@prefix pt: <https://socialcaredata.github.io/ontology/placements/vocab/placement-type#> .
@prefix pu: <https://socialcaredata.github.io/ontology/placements/vocab/placement-urgency#> .
@prefix rl: <https://socialcaredata.github.io/ontology/placements/vocab/risk-level#> .
@prefix sl: <https://socialcaredata.github.io/ontology/placements/vocab/suitability-level#> .
@prefix st: <https://socialcaredata.github.io/ontology/placements/vocab/support-type#> .
@prefix cln: <https://socialcaredata.github.io/ontology/placements/vocab/cultural-need#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix yns: <https://socialcaredata.github.io/ontology/placements/vocab/presence-status#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@base <https://socialcaredata.github.io/ontology/placements#> .

<https://socialcaredata.github.io/ontology/placements> rdf:type owl:Ontology ;
      owl:imports <https://raw.githubusercontent.com/SocialCareData/data-model/refs/heads/main/ontology/placements/vocab/communication-need.ttl> ,
                  <https://raw.githubusercontent.com/SocialCareData/data-model/refs/heads/main/ontology/placements/vocab/cultural-need.ttl> ,
                  <https://raw.githubusercontent.com/SocialCareData/data-model/refs/heads/main/ontology/placements/vocab/living-arrangement.ttl> ,
                  <https://raw.githubusercontent.com/SocialCareData/data-model/refs/heads/main/ontology/placements/vocab/pets-allowance.ttl> ,
                  <https://raw.githubusercontent.com/SocialCareData/data-model/refs/heads/main/ontology/placements/vocab/placement-type.ttl> ,
                  <https://raw.githubusercontent.com/SocialCareData/data-model/refs/heads/main/ontology/placements/vocab/placement-urgency.ttl> ,
                  <https://raw.githubusercontent.com/SocialCareData/data-model/refs/heads/main/ontology/placements/vocab/presence-status.ttl> ,
                  <https://raw.githubusercontent.com/SocialCareData/data-model/refs/heads/main/ontology/placements/vocab/risk-level.ttl> ,
                  <https://raw.githubusercontent.com/SocialCareData/data-model/refs/heads/main/ontology/placements/vocab/suitability-level.ttl> ,
                  <https://raw.githubusercontent.com/SocialCareData/data-model/refs/heads/main/ontology/placements/vocab/support-type.ttl> ;
      dct:creator "ODI / SocialCareData working group" ;
      dct:description "An OWL ontology that models the data captured by a local authority when arranging a placement for a looked-after child." ;
      dct:issued "2026-04-27"^^xsd:date ;
      dct:title "Children's Social Care Placements Ontology" ;
      rdfs:label "Placements Ontology" ;
      owl:versionInfo "1.0.0" .

#################################################################
#    Annotation properties
#################################################################

dct:creator rdf:type owl:AnnotationProperty .

dct:issued rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

xsd:date rdf:type rdfs:Datatype .

#################################################################
#    Object Properties
#################################################################

skos:inScheme rdf:type owl:ObjectProperty .

pl:additionalSupport rdf:type owl:ObjectProperty ;
                     rdfs:domain pl:PlacementRequirements ;
                     rdfs:range skos:Concept ;
                     rdfs:comment "Additional support provision required (e.g., additional supervision, therapeutic support, taxis to school). Multi-valued." ;
                     rdfs:label "additional support" ;
                     rdfs:seeAlso <https://socialcaredata.github.io/ontology/placements/vocab/support-type> .

pl:communicationNeeds rdf:type owl:ObjectProperty ,
                               owl:FunctionalProperty ;
                      rdfs:domain pl:PlacementRequirements ;
                      rdfs:range skos:Concept ;
                      rdfs:comment "Whether the child has any communication, language or learning needs." ;
                      rdfs:label "communication needs" ;
                      rdfs:seeAlso <https://socialcaredata.github.io/ontology/placements/vocab/presence-status> .

pl:culturalNeeds rdf:type owl:ObjectProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain pl:PlacementRequirements ;
                 rdfs:range cln:CulturalRequirement ;
                 rdfs:comment "Whether the placement must accommodate specific cultural needs (e.g., access to places of worship)." ;
                 rdfs:label "cultural needs" ;
                 rdfs:seeAlso <https://socialcaredata.github.io/ontology/placements/vocab/cultural-need> .

pl:fosterCareSuitability rdf:type owl:ObjectProperty ,
                                  owl:FunctionalProperty ;
                         rdfs:domain pl:PlacementRecommendation ;
                         rdfs:range skos:Concept ;
                         rdfs:comment "Suitability of foster care for this child, as judged by the social worker." ;
                         rdfs:label "foster care suitability" ;
                         rdfs:seeAlso <https://socialcaredata.github.io/ontology/placements/vocab/suitability-level> .

pl:hasActualPlacement rdf:type owl:ObjectProperty ,
                               owl:FunctionalProperty ;
                      rdfs:domain pl:Placement ;
                      rdfs:range pl:ActualPlacement ;
                      rdfs:comment "Links a Placement to the ActualPlacement that was arranged. Optional - a referral may exist without (yet) having an actual placement." ;
                      rdfs:label "has actual placement" .

pl:hasPlacementAvailability rdf:type owl:ObjectProperty ;
                            rdfs:subPropertyOf owl:topObjectProperty ;
                            rdfs:domain pl:Placement ;
                            rdfs:range pl:PlacementAvailability ;
                            rdfs:label "has placement availability" .

pl:hasPlacementRecommendation rdf:type owl:ObjectProperty ,
                                       owl:FunctionalProperty ;
                              rdfs:domain pl:Placement ;
                              rdfs:range pl:PlacementRecommendation ;
                              rdfs:comment "Links a Placement to its PlacementRecommendation." ;
                              rdfs:label "has placement recommendation" .

pl:hasPlacementRequirements rdf:type owl:ObjectProperty ,
                                     owl:FunctionalProperty ;
                            rdfs:domain pl:Placement ;
                            rdfs:range pl:PlacementRequirements ;
                            rdfs:comment "Links a Placement to its PlacementRequirements." ;
                            rdfs:label "has placement requirements" .

pl:hasQualityAssurance rdf:type owl:ObjectProperty ,
                                owl:FunctionalProperty ;
                       rdfs:domain pl:Placement ;
                       rdfs:range pl:QualityAssurance ;
                       rdfs:comment "Links a Placement to its QualityAssurance metadata." ;
                       rdfs:label "has quality assurance" .

pl:hasRiskAssessment rdf:type owl:ObjectProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain pl:Placement ;
                     rdfs:range pl:RiskAssessment ;
                     rdfs:comment "Links a Placement to its RiskAssessment." ;
                     rdfs:label "has risk assessment" .

pl:livingCompanions rdf:type owl:ObjectProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain pl:PlacementRequirements ;
                    rdfs:range skos:Concept ;
                    rdfs:comment "Recommendation as to who the child can be cared for alongside (e.g., solo placement, with other children, only older children)." ;
                    rdfs:label "living companions" ;
                    rdfs:seeAlso <https://socialcaredata.github.io/ontology/placements/vocab/living-arrangement> .

pl:neededBy rdf:type owl:ObjectProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain pl:PlacementAvailability ;
            rdfs:range skos:Concept ;
            rdfs:comment "When the child needs to be placed by. Captures urgency rather than an absolute date, as deep-dive participants felt 'date placement required by' was too subjective." ;
            rdfs:label "needed by" ;
            rdfs:seeAlso <https://socialcaredata.github.io/ontology/placements/vocab/placement-urgency> .

pl:pets rdf:type owl:ObjectProperty ,
                 owl:FunctionalProperty ;
        rdfs:domain pl:PlacementRequirements ;
        rdfs:range skos:Concept ;
        rdfs:comment "Whether the child can or must live in a home with pets/animals." ;
        rdfs:label "pets allowance" ;
        rdfs:seeAlso <https://socialcaredata.github.io/ontology/placements/vocab/pets-allowance> .

pl:placementType rdf:type owl:ObjectProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain pl:ActualPlacement ;
                 rdfs:range skos:Concept ;
                 rdfs:comment "The type of placement the child received." ;
                 rdfs:label "placement type" ;
                 rdfs:seeAlso <https://socialcaredata.github.io/ontology/placements/vocab/placement-type> .

pl:residentialCareSuitability rdf:type owl:ObjectProperty ,
                                       owl:FunctionalProperty ;
                              rdfs:domain pl:PlacementRecommendation ;
                              rdfs:range skos:Concept ;
                              rdfs:comment "Suitability of residential care for this child." ;
                              rdfs:label "residential care suitability" ;
                              rdfs:seeAlso <https://socialcaredata.github.io/ontology/placements/vocab/suitability-level> .

pl:riskCriminalExploitation rdf:type owl:ObjectProperty ,
                                     owl:FunctionalProperty ;
                            rdfs:domain pl:RiskAssessment ;
                            rdfs:range skos:Concept ;
                            rdfs:comment "Whether the child is known to be at risk of criminal exploitation." ;
                            rdfs:label "risk: criminal exploitation" ;
                            rdfs:seeAlso <https://socialcaredata.github.io/ontology/placements/vocab/risk-level> .

pl:riskDrugAlcohol rdf:type owl:ObjectProperty ,
                            owl:FunctionalProperty ;
                   rdfs:domain pl:RiskAssessment ;
                   rdfs:range skos:Concept ;
                   rdfs:comment "Whether the child is known to be at risk of drug and alcohol use." ;
                   rdfs:label "risk: drug and alcohol use" ;
                   rdfs:seeAlso <https://socialcaredata.github.io/ontology/placements/vocab/risk-level> .

pl:riskEatingDisorder rdf:type owl:ObjectProperty ,
                               owl:FunctionalProperty ;
                      rdfs:domain pl:RiskAssessment ;
                      rdfs:range skos:Concept ;
                      rdfs:comment "Whether the child is known to be at risk of an eating disorder." ;
                      rdfs:label "risk: eating disorder" ;
                      rdfs:seeAlso <https://socialcaredata.github.io/ontology/placements/vocab/risk-level> .

pl:riskMissing rdf:type owl:ObjectProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain pl:RiskAssessment ;
               rdfs:range skos:Concept ;
               rdfs:comment "Whether the child is known to be at risk of going missing." ;
               rdfs:label "risk: going missing" ;
               rdfs:seeAlso <https://socialcaredata.github.io/ontology/placements/vocab/risk-level> .

pl:riskSelfHarm rdf:type owl:ObjectProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain pl:RiskAssessment ;
                rdfs:range skos:Concept ;
                rdfs:comment "Whether the child is known to be at risk of self-harm." ;
                rdfs:label "risk: self-harm" ;
                rdfs:seeAlso <https://socialcaredata.github.io/ontology/placements/vocab/risk-level> .

pl:riskSexualExploitation rdf:type owl:ObjectProperty ,
                                   owl:FunctionalProperty ;
                          rdfs:domain pl:RiskAssessment ;
                          rdfs:range skos:Concept ;
                          rdfs:comment "Whether the child is known to be at risk of sexual exploitation." ;
                          rdfs:label "risk: sexual exploitation" ;
                          rdfs:seeAlso <https://socialcaredata.github.io/ontology/placements/vocab/risk-level> .

pl:riskToOthersAnimals rdf:type owl:ObjectProperty ,
                                owl:FunctionalProperty ;
                       rdfs:domain pl:RiskAssessment ;
                       rdfs:range skos:Concept ;
                       rdfs:comment "Whether there is a known risk of harm to animals." ;
                       rdfs:label "risk to others: harm to animals" ;
                       rdfs:seeAlso <https://socialcaredata.github.io/ontology/placements/vocab/risk-level> .

pl:riskToOthersCriminal rdf:type owl:ObjectProperty ,
                                 owl:FunctionalProperty ;
                        rdfs:domain pl:RiskAssessment ;
                        rdfs:range skos:Concept ;
                        rdfs:comment "Whether there is a known risk of criminal exploitation for others in the home." ;
                        rdfs:label "risk to others: criminal exploitation" ;
                        rdfs:seeAlso <https://socialcaredata.github.io/ontology/placements/vocab/risk-level> .

pl:riskToOthersFire rdf:type owl:ObjectProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain pl:RiskAssessment ;
                    rdfs:range skos:Concept ;
                    rdfs:comment "Whether there is a known risk of fire-setting." ;
                    rdfs:label "risk to others: fire-setting" ;
                    rdfs:seeAlso <https://socialcaredata.github.io/ontology/placements/vocab/risk-level> .

pl:riskToOthersPhysical rdf:type owl:ObjectProperty ,
                                 owl:FunctionalProperty ;
                        rdfs:domain pl:RiskAssessment ;
                        rdfs:range skos:Concept ;
                        rdfs:comment "Whether there is a known risk of physical harm to others." ;
                        rdfs:label "risk to others: physical harm" ;
                        rdfs:seeAlso <https://socialcaredata.github.io/ontology/placements/vocab/risk-level> .

pl:riskToOthersSexual rdf:type owl:ObjectProperty ,
                               owl:FunctionalProperty ;
                      rdfs:domain pl:RiskAssessment ;
                      rdfs:range skos:Concept ;
                      rdfs:comment "Whether there is a known risk of sexual harm to others." ;
                      rdfs:label "risk to others: sexual harm" ;
                      rdfs:seeAlso <https://socialcaredata.github.io/ontology/placements/vocab/risk-level> .

pl:specificCommunicationRequirement rdf:type owl:ObjectProperty ;
                                    rdfs:domain pl:PlacementRequirements ;
                                    rdfs:range skos:Concept ;
                                    rdfs:comment "Specific communication or language requirement (ESOL, BSL, Makaton, Other, None). Multi-valued: a placement may have several." ;
                                    rdfs:label "specific communication requirement" ;
                                    rdfs:seeAlso <https://socialcaredata.github.io/ontology/placements/vocab/communication-need> .

pl:supportedAccommodationSuitability rdf:type owl:ObjectProperty ,
                                              owl:FunctionalProperty ;
                                     rdfs:domain pl:PlacementRecommendation ;
                                     rdfs:range skos:Concept ;
                                     rdfs:comment "Suitability of supported accommodation for this child." ;
                                     rdfs:label "supported accommodation suitability" ;
                                     rdfs:seeAlso <https://socialcaredata.github.io/ontology/placements/vocab/suitability-level> .

#################################################################
#    Data properties
#################################################################

pl:additionalSupportOther rdf:type owl:DatatypeProperty ,
                                   owl:FunctionalProperty ;
                          rdfs:domain pl:PlacementRequirements ;
                          rdfs:range xsd:string ;
                          rdfs:comment "Free-text description of any additional support not captured by the standard SupportType options. Used when the 'Other' SupportType concept is selected." ;
                          rdfs:label "additional support: other (free text)" .

pl:childId rdf:type owl:DatatypeProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain pl:Placement ;
           rdfs:range xsd:string ;
           rdfs:comment "Identifier unique to each child within the LA, allowing linking between multiple referrals for the same child." ;
           rdfs:label "child ID" .

pl:costDate rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain pl:QualityAssurance ;
            rdfs:range xsd:date ;
            rdfs:comment "Date the placement cost data was captured." ;
            rdfs:label "cost date" .

pl:costOfficerName rdf:type owl:DatatypeProperty ,
                            owl:FunctionalProperty ;
                   rdfs:domain pl:QualityAssurance ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Name of the officer who recorded the placement cost data." ;
                   rdfs:label "cost officer name" .

pl:deprivationOfLiberty rdf:type owl:DatatypeProperty ,
                                 owl:FunctionalProperty ;
                        rdfs:domain pl:PlacementRequirements ;
                        rdfs:range xsd:boolean ;
                        rdfs:comment "Whether the child has a Deprivation of Liberty Order (DOL)." ;
                        rdfs:label "deprivation of liberty order" .

pl:homeAdaptationRequired rdf:type owl:DatatypeProperty ,
                                   owl:FunctionalProperty ;
                          rdfs:domain pl:PlacementRequirements ;
                          rdfs:range xsd:boolean ;
                          rdfs:comment "Whether adaptations to the home are required to accommodate the child's needs." ;
                          rdfs:label "home adaptation required" .

pl:isEducationContinuous rdf:type owl:DatatypeProperty ,
                                  owl:FunctionalProperty ;
                         rdfs:domain pl:ActualPlacement ;
                         rdfs:range xsd:boolean ;
                         rdfs:comment "Whether the child's education was continuous (i.e., not disrupted) as a result of this placement. In some cases an education disruption may be in line with the care plan." ;
                         rdfs:label "is education continuous" .

pl:isLocationPreferred rdf:type owl:DatatypeProperty ,
                                owl:FunctionalProperty ;
                       rdfs:domain pl:ActualPlacement ;
                       rdfs:range xsd:boolean ;
                       rdfs:comment "Whether the actual placement location was a preferred location." ;
                       rdfs:label "is location preferred" .

pl:placementDate rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain pl:QualityAssurance ;
                 rdfs:range xsd:date ;
                 rdfs:comment "Date the actual placement data was captured." ;
                 rdfs:label "placement date" .

pl:placementId rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain pl:PlacementAvailability ;
               rdfs:range xsd:string ;
               rdfs:comment "The unique identifier of the placement record within the LA case management system." ;
               rdfs:label "placement ID" .

pl:placementLocation rdf:type owl:DatatypeProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain pl:ActualPlacement ;
                     rdfs:range xsd:string ;
                     rdfs:comment "First 3-4 digits of the postcode for the actual placement location. Captured in addition to the provider URN to ensure location is recorded for non-registered placements." ;
                     rdfs:label "placement location" .

pl:placementOfficerName rdf:type owl:DatatypeProperty ,
                                 owl:FunctionalProperty ;
                        rdfs:domain pl:QualityAssurance ;
                        rdfs:range xsd:string ;
                        rdfs:comment "Name of the officer who recorded the actual placement information." ;
                        rdfs:label "placement officer name" .

pl:preferredLocation rdf:type owl:DatatypeProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain pl:PlacementAvailability ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Preferred area for the placement search. Free text in the current spec; an authoritative geographic vocabulary is still being explored." ;
                     rdfs:label "preferred location" .

pl:providerURN rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain pl:ActualPlacement ;
               rdfs:range xsd:string ;
               rdfs:comment "Provider Unique Reference Number, linked to Ofsted registration. Allows the placement to be linked to Ofsted data about the provider." ;
               rdfs:label "provider URN" .

pl:referralDate rdf:type owl:DatatypeProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain pl:QualityAssurance ;
                rdfs:range xsd:date ;
                rdfs:comment "Date the referral data was captured." ;
                rdfs:label "referral date" .

pl:referralOfficerName rdf:type owl:DatatypeProperty ,
                                owl:FunctionalProperty ;
                       rdfs:domain pl:QualityAssurance ;
                       rdfs:range xsd:string ;
                       rdfs:comment "Name of the officer who recorded the referral information. Used for LA-internal QA only." ;
                       rdfs:label "referral officer name" .

pl:riskOther rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain pl:RiskAssessment ;
             rdfs:range xsd:string ;
             rdfs:comment "Free-text description of any other risks the child is exposed to that are not captured by the standard risk fields." ;
             rdfs:label "risk: other (free text)" .

pl:riskToOthersOther rdf:type owl:DatatypeProperty ,
                              owl:FunctionalProperty ;
                     rdfs:domain pl:RiskAssessment ;
                     rdfs:range xsd:string ;
                     rdfs:comment "Free-text description of any other risks to others or property that are not captured by the standard risk-to-others fields." ;
                     rdfs:label "risk to others: other (free text)" .

pl:siblingCount rdf:type owl:DatatypeProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain pl:PlacementAvailability ;
                rdfs:range xsd:nonNegativeInteger ;
                rdfs:comment "How many siblings the child should ideally be placed with according to the care plan. 0 if the child has no siblings or is not to be placed with siblings." ;
                rdfs:label "sibling count" .

pl:siblingsPlacedTogether rdf:type owl:DatatypeProperty ,
                                   owl:FunctionalProperty ;
                          rdfs:domain pl:ActualPlacement ;
                          rdfs:range xsd:nonNegativeInteger ;
                          rdfs:comment "How many siblings were actually placed together. Allows comparison with the intended sibling count from the referral." ;
                          rdfs:label "siblings placed together" .

pl:totalWeeklyCost rdf:type owl:DatatypeProperty ,
                            owl:FunctionalProperty ;
                   rdfs:domain pl:ActualPlacement ;
                   rdfs:range xsd:decimal ;
                   rdfs:comment "Total weekly fee paid for the placement, excluding VAT. Captures the actual fee paid rather than the fee agreed at the point of IPA, as discussed in deep-dive sessions." ;
                   rdfs:label "total weekly cost" .


#################################################################
#    Classes
#################################################################

pl:ActualPlacement rdf:type owl:Class ;
                   rdfs:subClassOf [ rdf:type owl:Restriction ;
                                     owl:onProperty pl:placementType ;
                                     owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                         owl:onProperty skos:inScheme ;
                                                         owl:hasValue <https://socialcaredata.github.io/ontology/placements/vocab/placement-type>
                                                       ]
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty pl:totalWeeklyCost ;
                                     owl:cardinality "1"^^xsd:nonNegativeInteger
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty pl:placementLocation ;
                                     owl:cardinality "1"^^xsd:nonNegativeInteger
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty pl:isLocationPreferred ;
                                     owl:cardinality "1"^^xsd:nonNegativeInteger
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty pl:isEducationContinuous ;
                                     owl:cardinality "1"^^xsd:nonNegativeInteger
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty pl:providerURN ;
                                     owl:cardinality "1"^^xsd:nonNegativeInteger
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty pl:siblingsPlacedTogether ;
                                     owl:cardinality "1"^^xsd:nonNegativeInteger
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty pl:placementType ;
                                     owl:cardinality "1"^^xsd:nonNegativeInteger
                                   ] ;
                   rdfs:comment "Describes the placement actually arranged for the child, including weekly cost, location, provider URN, sibling co-placement and educational continuity. Optional - a Placement may not (yet) have an ActualPlacement." ;
                   rdfs:label "Actual Placement" .

pl:Placement rdf:type owl:Class ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty pl:childId ;
                               owl:cardinality "1"^^xsd:nonNegativeInteger
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty pl:hasPlacementAvailability ;
                               owl:cardinality "1"^^xsd:nonNegativeInteger
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty pl:hasPlacementRequirements ;
                               owl:cardinality "1"^^xsd:nonNegativeInteger
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty pl:hasPlacementRecommendation ;
                               owl:cardinality "1"^^xsd:nonNegativeInteger
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty pl:hasRiskAssessment ;
                               owl:cardinality "1"^^xsd:nonNegativeInteger
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty pl:hasQualityAssurance ;
                               owl:cardinality "1"^^xsd:nonNegativeInteger
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty pl:hasActualPlacement ;
                               owl:maxCardinality "1"^^xsd:nonNegativeInteger
                             ] ;
             rdfs:label "Placement" .

pl:PlacementAvailability rdf:type owl:Class ;
                         rdfs:subClassOf [ rdf:type owl:Restriction ;
                                           owl:onProperty pl:neededBy ;
                                           owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                               owl:onProperty skos:inScheme ;
                                                               owl:hasValue <https://socialcaredata.github.io/ontology/placements/vocab/placement-urgency>
                                                             ]
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty pl:placementId ;
                                           owl:cardinality "1"^^xsd:nonNegativeInteger
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty pl:neededBy ;
                                           owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty pl:siblingCount ;
                                           owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty pl:preferredLocation ;
                                           owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                         ] ;
                         rdfs:comment "A placement record covering the full lifecycle of a placement instance: the referral request (urgency, sibling count, preferred location), the social-worker recommendation, the placement requirements (needs), the risk assessment, the actual placement found (if any), and quality-assurance metadata. Equivalent to the central 'PlacementAvailability' table in the data model diagram." ;
                         rdfs:label "Placement Availability" ;
                         skos:altLabel "Placement Availability" ,
                                       "Placement Referral" .

pl:PlacementRecommendation rdf:type owl:Class ;
                           rdfs:subClassOf [ rdf:type owl:Restriction ;
                                             owl:onProperty pl:fosterCareSuitability ;
                                             owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                                 owl:onProperty skos:inScheme ;
                                                                 owl:hasValue <https://socialcaredata.github.io/ontology/placements/vocab/suitability-level>
                                                               ]
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty pl:fosterCareSuitability ;
                                             owl:cardinality "1"^^xsd:nonNegativeInteger
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty pl:residentialCareSuitability ;
                                             owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                                 owl:onProperty skos:inScheme ;
                                                                 owl:hasValue <https://socialcaredata.github.io/ontology/placements/vocab/suitability-level>
                                                               ]
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty pl:residentialCareSuitability ;
                                             owl:cardinality "1"^^xsd:nonNegativeInteger
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty pl:supportedAccommodationSuitability ;
                                             owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                                 owl:onProperty skos:inScheme ;
                                                                 owl:hasValue <https://socialcaredata.github.io/ontology/placements/vocab/suitability-level>
                                                               ]
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty pl:supportedAccommodationSuitability ;
                                             owl:cardinality "1"^^xsd:nonNegativeInteger
                                           ] ;
                           rdfs:comment "The social worker's recommendation of which categories of placement (foster, residential, supported accommodation) are preferred, suitable but not preferred, unsuitable, or unspecified." ;
                           rdfs:label "Placement Recommendation" .

pl:PlacementRequirements rdf:type owl:Class ;
                         rdfs:subClassOf [ rdf:type owl:Restriction ;
                                           owl:onProperty pl:additionalSupport ;
                                           owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                               owl:onProperty skos:inScheme ;
                                                               owl:hasValue <https://socialcaredata.github.io/ontology/placements/vocab/support-type>
                                                             ]
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty pl:communicationNeeds ;
                                           owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                               owl:onProperty skos:inScheme ;
                                                               owl:hasValue <https://socialcaredata.github.io/ontology/placements/vocab/presence-status>
                                                             ]
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty pl:communicationNeeds ;
                                           owl:cardinality "1"^^xsd:nonNegativeInteger
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty pl:culturalNeeds ;
                                           owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                               owl:onProperty skos:inScheme ;
                                                               owl:hasValue <https://socialcaredata.github.io/ontology/placements/vocab/cultural-need>
                                                             ]
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty pl:culturalNeeds ;
                                           owl:cardinality "1"^^xsd:nonNegativeInteger
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty pl:livingCompanions ;
                                           owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                               owl:onProperty skos:inScheme ;
                                                               owl:hasValue <https://socialcaredata.github.io/ontology/placements/vocab/living-arrangement>
                                                             ]
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty pl:livingCompanions ;
                                           owl:cardinality "1"^^xsd:nonNegativeInteger
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty pl:pets ;
                                           owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                               owl:onProperty skos:inScheme ;
                                                               owl:hasValue <https://socialcaredata.github.io/ontology/placements/vocab/pets-allowance>
                                                             ]
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty pl:pets ;
                                           owl:cardinality "1"^^xsd:nonNegativeInteger
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty pl:specificCommunicationRequirement ;
                                           owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                               owl:onProperty skos:inScheme ;
                                                               owl:hasValue <https://socialcaredata.github.io/ontology/placements/vocab/communication-need>
                                                             ]
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty pl:specificCommunicationRequirement ;
                                           owl:minCardinality "1"^^xsd:nonNegativeInteger
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty pl:homeAdaptationRequired ;
                                           owl:cardinality "1"^^xsd:nonNegativeInteger
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty pl:deprivationOfLiberty ;
                                           owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty pl:additionalSupport ;
                                           owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                         ] ;
                         rdfs:comment "Requirements describing the child's needs that the placement must accommodate: communication, cultural, living companions, pets, additional support, deprivation of liberty, home adaptation." ;
                         rdfs:label "Placement Requirements" .

pl:QualityAssurance rdf:type owl:Class ;
                    rdfs:subClassOf [ rdf:type owl:Restriction ;
                                      owl:onProperty pl:referralOfficerName ;
                                      owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty pl:referralDate ;
                                      owl:cardinality "1"^^xsd:nonNegativeInteger
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty pl:placementOfficerName ;
                                      owl:cardinality "1"^^xsd:nonNegativeInteger
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty pl:placementDate ;
                                      owl:cardinality "1"^^xsd:nonNegativeInteger
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty pl:costOfficerName ;
                                      owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty pl:costDate ;
                                      owl:cardinality "1"^^xsd:nonNegativeInteger
                                    ] ;
                    rdfs:comment "Metadata about who recorded each part of the placement record (referral, placement, cost) and when. Supports LA-internal review of data-entry practices; not intended to be shared beyond the recording LA." ;
                    rdfs:label "Quality Assurance" .

pl:RiskAssessment rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty pl:riskCriminalExploitation ;
                                    owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                        owl:onProperty skos:inScheme ;
                                                        owl:hasValue <https://socialcaredata.github.io/ontology/placements/vocab/risk-level>
                                                      ]
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty pl:riskCriminalExploitation ;
                                    owl:cardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty pl:riskDrugAlcohol ;
                                    owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                        owl:onProperty skos:inScheme ;
                                                        owl:hasValue <https://socialcaredata.github.io/ontology/placements/vocab/risk-level>
                                                      ]
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty pl:riskDrugAlcohol ;
                                    owl:cardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty pl:riskEatingDisorder ;
                                    owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                        owl:onProperty skos:inScheme ;
                                                        owl:hasValue <https://socialcaredata.github.io/ontology/placements/vocab/risk-level>
                                                      ]
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty pl:riskEatingDisorder ;
                                    owl:cardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty pl:riskMissing ;
                                    owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                        owl:onProperty skos:inScheme ;
                                                        owl:hasValue <https://socialcaredata.github.io/ontology/placements/vocab/risk-level>
                                                      ]
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty pl:riskMissing ;
                                    owl:cardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty pl:riskSelfHarm ;
                                    owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                        owl:onProperty skos:inScheme ;
                                                        owl:hasValue <https://socialcaredata.github.io/ontology/placements/vocab/risk-level>
                                                      ]
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty pl:riskSelfHarm ;
                                    owl:cardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty pl:riskSexualExploitation ;
                                    owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                        owl:onProperty skos:inScheme ;
                                                        owl:hasValue <https://socialcaredata.github.io/ontology/placements/vocab/risk-level>
                                                      ]
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty pl:riskSexualExploitation ;
                                    owl:cardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty pl:riskToOthersAnimals ;
                                    owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                        owl:onProperty skos:inScheme ;
                                                        owl:hasValue <https://socialcaredata.github.io/ontology/placements/vocab/risk-level>
                                                      ]
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty pl:riskToOthersAnimals ;
                                    owl:cardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty pl:riskToOthersCriminal ;
                                    owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                        owl:onProperty skos:inScheme ;
                                                        owl:hasValue <https://socialcaredata.github.io/ontology/placements/vocab/risk-level>
                                                      ]
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty pl:riskToOthersCriminal ;
                                    owl:cardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty pl:riskToOthersFire ;
                                    owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                        owl:onProperty skos:inScheme ;
                                                        owl:hasValue <https://socialcaredata.github.io/ontology/placements/vocab/risk-level>
                                                      ]
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty pl:riskToOthersFire ;
                                    owl:cardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty pl:riskToOthersPhysical ;
                                    owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                        owl:onProperty skos:inScheme ;
                                                        owl:hasValue <https://socialcaredata.github.io/ontology/placements/vocab/risk-level>
                                                      ]
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty pl:riskToOthersPhysical ;
                                    owl:cardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty pl:riskToOthersSexual ;
                                    owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                        owl:onProperty skos:inScheme ;
                                                        owl:hasValue <https://socialcaredata.github.io/ontology/placements/vocab/risk-level>
                                                      ]
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty pl:riskToOthersSexual ;
                                    owl:cardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty pl:riskOther ;
                                    owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty pl:riskToOthersOther ;
                                    owl:maxCardinality "1"^^xsd:nonNegativeInteger
                                  ] ;
                  rdfs:comment "Assessment of risks the child is exposed to (self-harm, sexual exploitation, criminal exploitation, drug/alcohol use, eating disorders, going missing) and risks the child poses to others or property (physical, sexual, fire-setting, animals, criminal exploitation). Each risk is recorded as 'no known risk' or 'risk present'." ;
                  rdfs:label "Risk Assessment" .

